{
  "name": "video-downloader-pro",
  "version": "1.0.0",
  "description": "Professional batch video downloader with modern UI",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1 -Clean",
    "dev:check": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1 -Check",
    "start": "./scripts/quick-start.bat",
    "build": "pnpm sidecars:check && tauri build",
    "build:local": "pnpm sidecars:check -- --allow-placeholders && tauri build --config src-tauri/tauri.conf.local.json --features local-logging",
    "build:prod": "pnpm sidecars:check && tauri build",
    "vite": "vite",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest --config vitest.config.integration.ts",
    "test:integration:ui": "vitest --config vitest.config.integration.ts --ui",
    "test:e2e": "vitest run --config vitest.config.integration.ts",
    "test:tauri-smoke": "node scripts/tauri-mcp-smoke.mjs",
    "test:all": "pnpm lint && pnpm type-check && pnpm exec vitest run && pnpm exec vitest run --config vitest.config.integration.ts && cargo fmt --manifest-path src-tauri/Cargo.toml --all --check && cargo test --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "sidecars:check": "node scripts/validate-sidecars.mjs",
    "sidecars:check:all": "node scripts/validate-sidecars.mjs --all",
    "sidecars:check:local": "node scripts/validate-sidecars.mjs --allow-placeholders",
    "sidecars:prepare": "node scripts/prepare-sidecars.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "audit:js": "pnpm audit --audit-level moderate",
    "audit:rust": "./scripts/audit-rust.sh",
    "audit:deps": "pnpm audit --audit-level moderate && ./scripts/audit-rust.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "@tanstack/react-virtual": "^3.11.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-os": "^2.1.0",
    "@tauri-apps/plugin-shell": "^2.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.0.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.5",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^15.4.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "ffmpeg-static": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.2",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.5",
    "ws": "^8.18.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@^1.0.0": "1.1.13",
      "minimatch@^3.0.0": "3.1.4",
      "picomatch@^2.0.0": "2.3.2",
      "picomatch@^4.0.0": "4.0.4",
      "postcss": "8.5.10",
      "yaml": "2.8.3"
    }
  },
  "packageManager": "pnpm@9.15.0"
}
